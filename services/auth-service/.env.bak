PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database (RDS in prod, docker-compose postgres in dev)
DB_HOST=postgres
DB_PORT=5432
DB_USER=ecommerce
DB_PASSWORD=devpassword
DB_NAME=ecommerce
DB_POOL_MAX=10

# JWT
JWT_SECRET=replace-me-in-production
JWT_TTL=24h

# CORS — comma-separated list of allowed origins for local dev
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
